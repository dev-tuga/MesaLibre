# PostgreSQL connection string (matches docker-compose.yml defaults)
DATABASE_URL="postgresql://mesalibre:mesalibre@localhost:5432/mesalibre"

# Payment provider ("mock" is the only implementation for now)
PAYMENT_PROVIDER="mock"

# NextAuth session secret — generate one with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-random-32-byte-base64-string"
